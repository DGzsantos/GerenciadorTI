# ─────────────────────────────────────────────────────────────
# Gerenciador de TI — Variáveis de ambiente locais
# Copie este arquivo para ".env" e preencha os valores.
# O arquivo ".env" está no .gitignore e nunca deve ser comitado.
# ─────────────────────────────────────────────────────────────

# ── Supabase ────────────────────────────────────────────────
# Obtenha em: https://app.supabase.com → seu projeto → Settings → API
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_ANON_KEY=eyJhbGci...sua_chave_anon_aqui

# ── Servidor local (opcional) ───────────────────────────────
PORT=8000
