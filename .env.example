# ─────────────────────────────────────────────────
# Gerenciador de TI — Variáveis de Ambiente
# Copie este arquivo para .env e ajuste os valores
# ─────────────────────────────────────────────────

APP_NAME="Gerenciador de TI"
APP_VERSION="1.0.0"
DEBUG=false

# Banco de dados (SQLite local)
DATABASE_URL=sqlite+aiosqlite:///./gerenciador_ti.db

# Para migrar para Supabase/PostgreSQL, altere para:
# DATABASE_URL=postgresql+asyncpg://usuario:senha@host:5432/banco

# JWT — GERE UMA CHAVE FORTE: openssl rand -hex 32
SECRET_KEY=TROQUE-ESTA-CHAVE-EM-PRODUCAO-USE-OPENSSL-RAND-HEX-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS (lista separada por vírgula em produção)
ALLOWED_ORIGINS=["*"]

# Logs
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
